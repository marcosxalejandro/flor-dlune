# Spotify API credentials (for 30-second track previews)
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here

# Site URL (production: https://flordlune.com)
NEXT_PUBLIC_SITE_URL=https://flordlune.com

# Stripe — https://dashboard.stripe.com (NL account)
# Gebruik test keys voor development, live keys voor productie
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Admin panel (/admin) — kies een sterk wachtwoord
ADMIN_SECRET=jouw-geheime-admin-key

# Print-on-demand suppliers
# Gelato (NL/EU productie, 2-3 dagen) — https://dashboard.gelato.com
GELATO_API_KEY=

# Printful (sokken + backup) — https://www.printful.com/dashboard/api
PRINTFUL_API_KEY=

# Automatisch doorsturen na betaling (optioneel, standaard: handmatig via admin)
AUTO_FORWARD_ORDERS=false